{
  "name": "@openmirai/mirai-intl",
  "version": "0.1.5",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/openmirai/mirai-intl.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "benchmark": "tsx benchmarks/run.ts",
    "build": "tsdown",
    "check:generated": "tsx scripts/check-generated.ts",
    "clean": "rimraf packages/*/dist packages/*/tsconfig.tsbuildinfo *.tsbuildinfo coverage .tmp",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "generate:fixtures": "tsx scripts/generate-fixtures.ts",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint --fix --fix-suggestions . && oxfmt --write .",
    "pack:smoke": "tsx scripts/pack-smoke.ts",
    "prepare": "husky",
    "pretest": "corepack pnpm build",
    "release": "release-it",
    "release:prerelease": "release-it --preRelease=beta",
    "release:packages:dry-run": "node scripts/publish-packages.mjs --dry-run",
    "test": "vitest run",
    "typecheck": "tsc -b --force --pretty false && tsc -p tsconfig.tools.json --pretty false",
    "typecheck:fixtures": "tsx scripts/type-fixtures.ts",
    "verify": "corepack pnpm format && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm typecheck:fixtures && corepack pnpm test && corepack pnpm check:generated && corepack pnpm benchmark && corepack pnpm pack:smoke"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@commitlint/types": "21.2.0",
    "@openmirai/intl-abi": "workspace:*",
    "@openmirai/intl-compiler": "workspace:*",
    "@openmirai/intl-runtime": "workspace:*",
    "@opentelemetry/api-logs": "^0.220.0",
    "@release-it/bumper": "7.0.6",
    "@release-it/conventional-changelog": "11.0.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-test-renderer": "19.1.0",
    "husky": "9.1.7",
    "i18next": "26.3.6",
    "i18next-icu": "2.4.4",
    "intl-messageformat": "11.2.11",
    "lint-staged": "17.0.8",
    "next": "16.2.9",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.9",
    "react-test-renderer": "19.2.7",
    "release-it": "20.2.1",
    "rimraf": "6.1.3",
    "tsdown": "0.22.7",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "typescript-5-9": "npm:typescript@5.9.3",
    "typescript-6": "npm:typescript@6.0.3",
    "typescript-7": "npm:typescript@7.0.2",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
