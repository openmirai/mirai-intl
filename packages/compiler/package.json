{
  "name": "@openmirai/intl-compiler",
  "version": "0.1.1-beta.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/openmirai/mirai-intl.git",
    "directory": "packages/compiler"
  },
  "bin": {
    "mirai-intl": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "default": "./dist/next.js"
    },
    "./transform": {
      "types": "./dist/transform.d.ts",
      "import": "./dist/transform.js",
      "default": "./dist/transform.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "default": "./dist/vite.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@formatjs/icu-messageformat-parser": "3.5.14",
    "@openmirai/intl-abi": "workspace:*",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24"
  }
}
